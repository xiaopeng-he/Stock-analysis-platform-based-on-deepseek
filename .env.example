# DeepSeek API Key（必填，从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE

# DeepSeek API Base URL（默认值通常不需要改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-chat

# 服务配置
HOST=0.0.0.0
PORT=8000

# 缓存配置（秒）
CACHE_PRICE_TTL=3
CACHE_AI_TTL=60
CACHE_NEWS_TTL=300
